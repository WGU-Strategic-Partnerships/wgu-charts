{
  "name": "wgu-charts",
  "version": "0.7.0",
  "description": "WGU-branded, dynamic Chart.js chart library",
  "type": "module",
  "main": "./dist/wgu-charts.umd.js",
  "module": "./dist/wgu-charts.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/wgu-charts.esm.js",
      "require": "./dist/wgu-charts.umd.js"
    },
    "./vanilla": { "types": "./dist/vanilla.d.ts", "import": "./dist/vanilla.js" },
    "./react":   { "types": "./dist/react.d.ts",   "import": "./dist/react.js" },
    "./echarts": { "types": "./dist/echarts.d.ts", "import": "./dist/echarts.js" },
    "./corpus": { "types": "./dist/corpus.d.ts", "import": "./dist/corpus.js" }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "chart.js": "^4.4.0",
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "echarts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "chart.js": "^4.4.4",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
